---
import Layout from './Layout.astro';
import Reveal from '../components/Reveal.astro';
import Orbs from '../components/Orbs.astro';
import { useT, isRTL, localePath, type Locale } from '../i18n/translations';

interface PricingTier {
  name: string; price: string; period?: string; desc: string;
  features: string[]; featured?: boolean; cta?: string;
}
interface Props {
  locale: Locale;
  seoTitle?: string;
  eyebrow: string;
  headline: string;
  subline: string;
  tiers: PricingTier[];
  faqs?: { q: string; a: string }[];
  otherServices?: { label: string; href: string }[];
}
const { locale, seoTitle, eyebrow, headline, subline, tiers, faqs = [], otherServices = [] } = Astro.props;
const tr = useT(locale);
const rtl = isRTL(locale);
---
<Layout title={seoTitle} locale={locale}>
  <section class="ph-hero">
    <Orbs />
    <div class={`container ph-content${rtl ? ' rtl' : ''}`}>
      <Reveal>
        <a href={localePath(locale, '/#services')} class="back-link">
          {rtl
            ? <><span>{tr.pricing.backLink}</span><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 10h12M10 4l6 6-6 6"/></svg></>
            : <><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M16 10H4M10 4l-6 6 6 6"/></svg><span>{tr.pricing.backLink}</span></>
          }
        </a>
        <div class="ph-eyebrow">{eyebrow}</div>
        <h1 class="ph-title" set:html={headline} />
        <p class="ph-sub">{subline}</p>
      </Reveal>
    </div>
  </section>

  <section class="pt-section">
    <div class="container">
      <div class={`tiers-grid tiers-${tiers.length}`}>
        {tiers.map((tier, i) => (
          <Reveal delay={i * 90}>
            <div class={`tier-card${tier.featured ? ' tier-featured' : ''}${rtl ? ' rtl' : ''}`}>
              {tier.featured && <div class="tier-badge">{tr.pricing.mostPopular}</div>}
              <div class="tier-top">
                <div class="tier-name">{tier.name}</div>
                <div class="tier-price">
                  {tier.price.startsWith('$') ? <><sup>$</sup>{tier.price.slice(1)}</> : tier.price}
                </div>
                {tier.period && <div class="tier-period">{tier.period}</div>}
                <p class="tier-desc">{tier.desc}</p>
              </div>
              <ul class="tier-features">
                {tier.features.map(f => (
                  <li>
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 8l3.5 3.5L13 4"/></svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href={`/${locale}/#contact`} class={`tier-btn${tier.featured ? ' tier-btn-featured' : ''}`}>
                {tier.cta ?? tr.pricing.getStarted} →
              </a>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="faq-section">
      <div class={`container faq-inner${rtl ? ' rtl' : ''}`}>
        <Reveal>
          <div class="eyebrow">{tr.pricing.commonQuestions}</div>
          <h2 class="faq-title">{tr.pricing.faq}</h2>
        </Reveal>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <Reveal delay={i * 60}>
              <details class="faq-item">
                <summary>{faq.q}<span class="faq-icon">+</span></summary>
                <p>{faq.a}</p>
              </details>
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )}

  {otherServices.length > 0 && (
    <section class="other-section">
      <div class="container">
        <Reveal>
          <div class="eyebrow">{tr.pricing.exploreMore}</div>
          <h2 class="other-title">{tr.pricing.otherServices}</h2>
        </Reveal>
        <div class="other-grid">
          {otherServices.map((s, i) => (
            <Reveal delay={i * 70}>
              <a href={s.href} class={`other-card${rtl ? ' rtl' : ''}`}>
                <span>{s.label}</span>
                <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                  {rtl ? <path d="M16 10H4M10 4l-6 6 6 6"/> : <path d="M4 10h12M10 4l6 6-6 6"/>}
                </svg>
              </a>
            </Reveal>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="cta-banner">
    <Orbs />
    <div class="container cta-inner">
      <Reveal>
        <h2>{tr.pricing.readyTitle} <em>{tr.pricing.readyTitleEm}</em></h2>
        <p>{tr.pricing.readySub}</p>
        <a href="mailto:hello@26mhstudio.com" class="btn-cta">{tr.pricing.sendMsg}</a>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
.ph-hero { padding: 160px 0 100px; position: relative; overflow: hidden; border-bottom: 1px solid var(--border); }
.ph-content { position: relative; z-index: 2; max-width: 720px; }
.ph-content.rtl { text-align: right; margin-left: auto; margin-right: 0; }
.back-link { display: inline-flex; align-items: center; gap: 8px; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; margin-bottom: 36px; transition: color 0.2s; }
.back-link:hover { color: var(--purple); }
.back-link svg { width: 16px; height: 16px; }
.ph-eyebrow { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--purple); margin-bottom: 20px; }
.ph-title { font-family: 'Syne', sans-serif; font-size: clamp(42px, 6vw, 88px); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 28px; }
.ph-title :global(em) { font-style: italic; color: var(--purple); }
.ph-sub { font-size: 1rem; line-height: 1.8; color: var(--muted); max-width: 520px; }
.ph-content.rtl .ph-sub { margin-right: 0; margin-left: auto; }

.pt-section { padding: 100px 0; }
.tiers-grid { display: grid; gap: 2px; background: var(--border); }
.tiers-2 { grid-template-columns: repeat(2,1fr); }
.tiers-3 { grid-template-columns: repeat(3,1fr); }
.tiers-4 { grid-template-columns: repeat(4,1fr); }

.tier-card { background: var(--bg-card); padding: 52px 40px; position: relative; display: flex; flex-direction: column; transition: background 0.3s; }
.tier-card.rtl { text-align: right; }
.tier-card:hover { background: #1c1c30; }
.tier-featured { background: #16162a; outline: 1px solid var(--purple); outline-offset: -1px; }
.tier-badge { position: absolute; top: -1px; left: 50%; transform: translateX(-50%); background: var(--purple); color: var(--bg); font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; padding: 5px 18px; white-space: nowrap; font-family: 'Syne', sans-serif; }
.tier-name { font-family: 'Syne', sans-serif; font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-bottom: 16px; }
.tier-price { font-family: 'Syne', sans-serif; font-size: 3.2rem; font-weight: 800; color: var(--white); line-height: 1; margin-bottom: 4px; }
.tier-price sup { font-size: 1.2rem; font-weight: 400; vertical-align: top; margin-top: 10px; display: inline-block; }
.tier-period { font-size: 0.75rem; color: var(--muted); letter-spacing: 0.08em; margin-bottom: 20px; }
.tier-desc { font-size: 0.85rem; line-height: 1.7; color: var(--muted); }
.tier-top { margin-bottom: 36px; }
.tier-features { list-style: none; flex: 1; margin-bottom: 36px; display: flex; flex-direction: column; }
.tier-features li { display: flex; align-items: flex-start; gap: 10px; padding: 11px 0; font-size: 0.85rem; color: var(--muted); border-bottom: 1px solid var(--border); }
.tier-card.rtl .tier-features li { flex-direction: row-reverse; }
.tier-features li svg { width: 14px; height: 14px; color: var(--purple); flex-shrink: 0; margin-top: 2px; }
.tier-btn { display: block; text-align: center; padding: 14px; font-family: 'Syne', sans-serif; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; border-radius: 2px; border: 1px solid var(--border); color: var(--white); background: transparent; transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.2s; }
.tier-btn:hover { border-color: var(--purple); color: var(--purple); transform: translateY(-2px); }
.tier-btn-featured { background: var(--purple); color: var(--bg); border-color: var(--purple); }
.tier-btn-featured:hover { background: var(--purple-light); border-color: var(--purple-light); color: var(--bg); }

.faq-section { padding: 100px 0; background: var(--bg-surface); }
.faq-inner { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: start; }
.faq-inner.rtl { direction: rtl; }
.eyebrow { font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--purple); margin-bottom: 12px; display: block; }
.faq-title { font-family: 'Syne', sans-serif; font-size: clamp(28px,3vw,44px); font-weight: 800; letter-spacing: -0.03em; }
.faq-list { display: flex; flex-direction: column; }
.faq-item { border-bottom: 1px solid var(--border); cursor: pointer; }
.faq-item summary { display: flex; justify-content: space-between; align-items: center; padding: 22px 0; font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 600; list-style: none; color: var(--white); transition: color 0.2s; gap: 16px; }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item[open] summary { color: var(--purple); }
.faq-icon { font-size: 1.2rem; color: var(--purple); transition: transform 0.3s; flex-shrink: 0; font-weight: 300; }
.faq-item[open] .faq-icon { transform: rotate(45deg); }
.faq-item p { font-size: 0.88rem; line-height: 1.8; color: var(--muted); padding: 0 0 22px; }

.other-section { padding: 100px 0; }
.other-title { font-family: 'Syne', sans-serif; font-size: clamp(28px,3vw,44px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 48px; }
.other-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; background: var(--border); }
.other-card { background: var(--bg-card); padding: 32px 36px; display: flex; justify-content: space-between; align-items: center; font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 600; text-decoration: none; color: var(--white); transition: background 0.25s, color 0.25s; }
.other-card.rtl { flex-direction: row-reverse; }
.other-card svg { width: 20px; height: 20px; transition: transform 0.25s; color: var(--purple); }
.other-card:hover { background: #1c1c30; color: var(--purple); }
.other-card:not(.rtl):hover svg { transform: translateX(6px); }
.other-card.rtl:hover svg { transform: translateX(-6px); }

.cta-banner { padding: 140px 0; text-align: center; position: relative; overflow: hidden; }
.cta-inner { position: relative; z-index: 2; }
.cta-banner h2 { font-family: 'Syne', sans-serif; font-size: clamp(36px,5vw,72px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 16px; }
.cta-banner h2 em { font-style: italic; color: var(--purple); }
.cta-banner p { font-size: 0.95rem; color: var(--muted); margin-bottom: 40px; }
.btn-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--purple); color: var(--bg); padding: 18px 44px; font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; border-radius: 2px; transition: background 0.2s, transform 0.2s; }
.btn-cta:hover { background: var(--purple-light); transform: translateY(-2px); }

@media (max-width: 1000px) { .tiers-4 { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 860px) { .tiers-3, .tiers-2 { grid-template-columns: 1fr; } .faq-inner { grid-template-columns: 1fr; gap: 40px; } .other-grid { grid-template-columns: 1fr; } }
@media (max-width: 600px) { .tiers-4 { grid-template-columns: 1fr; } }
</style>
