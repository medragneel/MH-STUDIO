---
import '../styles/global.css';
import { locales, localeLabels, isRTL, useT, localePath, type Locale } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
const tr = useT(locale);
const rtl = isRTL(locale);
const dir = rtl ? 'rtl' : 'ltr';

const services = [
  { label: tr.services.s01.title, href: localePath(locale, '/pricing/brand-identity') },
  { label: tr.services.s02.title, href: localePath(locale, '/pricing/ai-video') },
  { label: tr.services.s03.title, href: localePath(locale, '/pricing/social-media') },
  { label: tr.services.s04.title, href: localePath(locale, '/pricing/3d-modeling') },
];
---

<!doctype html>
<html lang={locale} dir={dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description ?? tr.siteDesc} />
  <title>{title ?? tr.siteTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  {locale === 'ar' && (
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  )}
</head>
<body class={rtl ? 'rtl' : 'ltr'}>

  <!-- NAV -->
  <header id="site-nav">
    <div class="container nav-inner">
      <a href={localePath(locale, '/')} class="logo">
        <img src="/logo.svg" alt="Mh-Studio-logo" />
      </a>

      <button class="burger" id="burger" aria-label="Toggle menu">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav-links" id="nav-links">
        <a href={localePath(locale, '/#services')}>{tr.nav.services}</a>
        <a href={localePath(locale, '/#work')}>{tr.nav.work}</a>
        <a href={localePath(locale, '/pricing/brand-identity')}>{tr.nav.pricing}</a>
        <a href={localePath(locale, '/#about')}>{tr.nav.about}</a>

        <!-- Language switcher -->
        <div class="lang-switcher">
          {locales.map(l => (
            <a
              href={`/${l}/`}
              class={`lang-btn ${l === locale ? 'lang-active' : ''}`}
              lang={l}
            >
              {localeLabels[l]}
            </a>
          ))}
        </div>

        <a href={localePath(locale, '/#contact')} class="nav-cta">{tr.nav.cta}</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <div class="footer-brand">
                    <a href={localePath(locale, '/')} class="logo">
                        <img src="/logo.svg" alt="Mh-Studio-logo" />

                    </a>
        <p>{tr.footer.desc}</p>
        <div class="socials">
          <a href="https://www.instagram.com/26.mh_studio/" target="_blank" rel="noopener" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{tr.footer.colServices}</div>
        {services.map(s => <a href={s.href}>{s.label}</a>)}
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{tr.footer.colStudio}</div>
        <a href={localePath(locale, '/#work')}>{tr.footer.portfolio}</a>
        <a href={localePath(locale, '/#about')}>{tr.footer.about}</a>
        <a href={localePath(locale, '/#contact')}>{tr.footer.contact}</a>
      </div>

      <div class="footer-col">
        <div class="footer-col-title">{locale === 'ar' ? 'اللغة' : locale === 'fr' ? 'Langue' : 'Language'}</div>
        {locales.map(l => (
          <a href={`/${l}/`} class={l === locale ? 'lang-footer-active' : ''} lang={l}>
            {localeLabels[l]}
          </a>
        ))}
      </div>
    </div>

    <div class="footer-bottom container">
      <span>{tr.footer.rights}</span>
      <span>{tr.footer.crafted}</span>
    </div>
  </footer>

</body>
</html>

<style is:global>
/* Arabic font override */
:lang(ar), :lang(ar) * {
  font-family: 'Noto Kufi Arabic', 'Syne', sans-serif !important;
}
:lang(ar) .logo,
:lang(ar) .logo em {
  font-family: 'Syne', sans-serif !important;
}

/* RTL layout flips */
.rtl .nav-inner { flex-direction: row-reverse; }
.rtl .nav-links { flex-direction: row-reverse; }
.rtl .lang-switcher { flex-direction: row-reverse; }
.rtl .footer-bottom { flex-direction: row-reverse; }

/* NAV */
#site-nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 200;
  transition: background 0.3s, padding 0.3s;
  padding: 24px 0;
}
#site-nav.scrolled {
  background: rgba(8,8,15,0.93);
  backdrop-filter: blur(16px);
  padding: 14px 0;
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
}
.logo {
  font-family: 'Syne', sans-serif !important;
  font-weight: 800; font-size: 1.25rem;
  text-decoration: none; color: var(--white);
  letter-spacing: -0.02em; flex-shrink: 0;
}
.logo span { color: var(--purple); }
.logo em { font-style: normal; color: var(--muted); font-weight: 400; font-size: 0.85em; margin-left: 1px; }
.nav-links {
  display: flex; align-items: center; gap: 28px;
}
.nav-links > a {
  font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--muted); text-decoration: none; transition: color 0.2s;
  white-space: nowrap;
}
.nav-links > a:hover { color: var(--white); }

/* Language switcher */
.lang-switcher {
  display: flex; align-items: center; gap: 2px;
  background: rgba(147,144,223,0.08);
  border: 1px solid var(--border);
  border-radius: 4px; padding: 3px;
}
.lang-btn {
  font-size: 0.68rem !important; letter-spacing: 0.04em !important;
  text-transform: none !important; padding: 5px 10px;
  border-radius: 2px; color: var(--muted) !important;
  text-decoration: none; transition: background 0.2s, color 0.2s !important;
  white-space: nowrap;
}
.lang-btn:hover { color: var(--white) !important; background: rgba(147,144,223,0.12); }
.lang-active {
  background: var(--purple) !important;
  color: var(--bg) !important;
  font-weight: 600 !important;
}
.lang-footer-active { color: var(--purple) !important; }

.nav-cta {
  background: var(--purple) !important;
  color: var(--bg) !important;
  padding: 10px 20px !important;
  font-weight: 500 !important; border-radius: 2px;
  transition: background 0.2s, transform 0.2s !important;
  white-space: nowrap;
}
.nav-cta:hover { background: var(--purple-light) !important; transform: translateY(-1px); }

.burger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 4px;
}
.burger span { display: block; width: 24px; height: 2px; background: var(--white); border-radius: 1px; transition: all 0.3s; }

/* FOOTER */
footer { margin-top: 120px; border-top: 1px solid var(--border); padding-top: 80px; }
.footer-inner {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px; padding-bottom: 60px;
}
.footer-brand .logo { display: inline-block; margin-bottom: 16px; }
.footer-brand p { font-size: 0.85rem; line-height: 1.8; color: var(--muted); max-width: 260px; }
.socials { margin-top: 20px; display: flex; gap: 12px; }
.socials a {
  width: 36px; height: 36px; border: 1px solid var(--border); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--muted); text-decoration: none; transition: border-color 0.2s, color 0.2s;
}
.socials a:hover { border-color: var(--purple); color: var(--purple); }
.socials svg { width: 16px; height: 16px; }
.footer-col { display: flex; flex-direction: column; gap: 12px; }
.footer-col-title { font-family: 'Syne', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); margin-bottom: 4px; font-weight: 500; }
.footer-col a { font-size: 0.85rem; color: var(--muted); text-decoration: none; transition: color 0.2s; width: fit-content; }
.footer-col a:hover { color: var(--purple); }
.footer-bottom {
  border-top: 1px solid var(--border); padding-top: 28px; padding-bottom: 40px;
  display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--muted);
}

/* RTL footer */
.rtl .footer-brand p { direction: rtl; }
.rtl .footer-col { align-items: flex-end; text-align: right; }

/* MOBILE */
@media (max-width: 900px) {
  .burger { display: flex; }
  .nav-links {
    display: none; flex-direction: column;
    position: fixed; inset: 0;
    background: rgba(8,8,15,0.97); backdrop-filter: blur(20px);
    align-items: center; justify-content: center;
    gap: 28px; z-index: 199;
  }
  .nav-links.open { display: flex; }
  .nav-links > a { font-size: 1.1rem; }
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 36px; }
  .footer-brand { grid-column: 1 / -1; }
  .footer-bottom { flex-direction: column; gap: 8px; }
}
@media (max-width: 480px) {
  .footer-inner { grid-template-columns: 1fr; }
}
</style>

<script>
  const nav = document.getElementById('site-nav');
  window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));
  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('nav-links');
  burger?.addEventListener('click', () => navLinks?.classList.toggle('open'));
  navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));
</script>
