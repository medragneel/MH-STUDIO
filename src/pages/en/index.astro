---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import Orbs from '../../components/Orbs.astro';
import InstagramGrid from '../../components/InstagramGrid.astro';
import { useT, isRTL, localePath, type Locale } from '../../i18n/translations';

const locale: Locale = 'en';
const tr = useT(locale);
const rtl = isRTL(locale);

const serviceList = [
  { key: 's01', href: localePath(locale, '/pricing/brand-identity'), icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="24" cy="24" r="16"/><path d="M24 8v32M8 24h32M12 12l24 24M36 12L12 36"/></svg>` },
  { key: 's02', href: localePath(locale, '/pricing/ai-video'),       icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="10" width="30" height="28" rx="3"/><path d="M34 18l10-6v24l-10-6V18z"/><circle cx="14" cy="24" r="4"/></svg>` },
  { key: 's03', href: localePath(locale, '/pricing/social-media'),   icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="16" height="16" rx="2"/><rect x="26" y="6" width="16" height="16" rx="2"/><rect x="6" y="26" width="16" height="16" rx="2"/><rect x="26" y="26" width="16" height="16" rx="2"/></svg>` },
  { key: 's04', href: localePath(locale, '/pricing/3d-modeling'),    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M24 4l18 10v20L24 44 6 34V14L24 4z"/><path d="M24 4v40M6 14l18 10 18-10"/></svg>`, tag: true },
];

const works = [
  { title: 'Lumière Parfums',    cat: locale === 'ar' ? 'هوية بصرية' : locale === 'fr' ? 'Identité de Marque' : 'Brand Identity',     style: 'w1' },
  { title: 'Orbit Tech',         cat: locale === 'ar' ? 'مجموعة سوشيال ميديا' : locale === 'fr' ? 'Kit Réseaux Sociaux' : 'Social Media Kit', style: 'w2' },
  { title: 'Nova Drinks',        cat: locale === 'ar' ? 'فيديو AI للمنتجات' : locale === 'fr' ? 'Vidéo IA Produits' : 'AI Product Video', style: 'w3' },
  { title: 'Slate Architecture', cat: locale === 'ar' ? 'هوية بصرية' : locale === 'fr' ? 'Identité de Marque' : 'Brand Identity',     style: 'w4' },
  { title: 'Cleo Cosmetics',     cat: locale === 'ar' ? 'تصميم كتالوج' : locale === 'fr' ? 'Design Catalogue' : 'Catalog Design',    style: 'w5' },
  { title: 'Pulse Fitness',      cat: locale === 'ar' ? 'منشورات سوشيال ميديا' : locale === 'fr' ? 'Posts Réseaux Sociaux' : 'Social Media Posts', style: 'w6' },
];
---

<Layout locale={locale}>
  <!-- HERO -->
  <section class="hero">
    <Orbs />
    <div class="hero-noise" aria-hidden="true"></div>
    <div class={`container hero-content${rtl ? ' rtl' : ''}`}>
      <div class="hero-label"><span class="dot"></span>{tr.hero.badge}</div>
      <h1 class="hero-title">
        <span class="line-wrap"><span class="line">{tr.hero.line1}</span></span>
        <span class="line-wrap"><span class="line accent-word">{tr.hero.line2a}</span> <span class="line italic-word">{tr.hero.line2b}</span></span>
      </h1>
      <p class="hero-sub">{tr.hero.sub}</p>
      <div class="hero-actions">
        <a href={localePath(locale, '/#services')} class="btn-primary">{tr.hero.btnServices}</a>
        <a href={localePath(locale, '/#work')} class="btn-outline">{tr.hero.btnWork}</a>
      </div>
      <div class="hero-marquee" aria-hidden="true">
        <div class="marquee-track">
          <span>{tr.services.s01.title}</span><span class="sep">✦</span>
          <span>{tr.services.s02.title}</span><span class="sep">✦</span>
          <span>{tr.services.s03.title}</span><span class="sep">✦</span>
          <span>{tr.services.s04.title}</span><span class="sep">✦</span>
          <span>{tr.services.s01.title}</span><span class="sep">✦</span>
          <span>{tr.services.s02.title}</span><span class="sep">✦</span>
          <span>{tr.services.s03.title}</span><span class="sep">✦</span>
          <span>{tr.services.s04.title}</span><span class="sep">✦</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll"><div class="scroll-line"></div><span>↓</span></div>
  </section>

  <!-- SERVICES -->
  <section class="section" id="services">
    <div class="container">
      <Reveal>
        <div class={`section-head${rtl ? ' rtl' : ''}`}>
          <div class="eyebrow">{tr.sections.whatWeDo}</div>
          <h2 class="section-title">{tr.sections.services}</h2>
        </div>
      </Reveal>
      <div class="services-grid">
        {serviceList.map((s, i) => {
          const svc = tr.services[s.key as keyof typeof tr.services];
          return (
            <Reveal delay={i * 80}>
              <a href={s.href} class={`service-card${s.tag ? ' coming-soon-card' : ''}${rtl ? ' rtl' : ''}`}>
                <div class="sc-header">
                  <span class="sc-num">{svc.num}</span>
                  {s.tag && <span class="sc-tag">{tr.services.s04.tag}</span>}
                </div>
                <div class="sc-icon" set:html={s.icon} />
                <h3 class="sc-title">{svc.title}</h3>
                <p class="sc-desc">{svc.desc}</p>
                <div class="sc-cta">
                  {svc.cta}
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                    {rtl ? <path d="M16 10H4M10 4l-6 6 6 6"/> : <path d="M4 10h12M10 4l6 6-6 6"/>}
                  </svg>
                </div>
              </a>
            </Reveal>
          );
        })}
      </div>
    </div>
  </section>

  <!-- WORK -->
  <section class="section" id="work">
    <div class="container">
      <Reveal>
        <div class={`section-head split${rtl ? ' rtl' : ''}`}>
          <div>
            <div class="eyebrow">{tr.sections.selectedProjects}</div>
            <h2 class="section-title">{tr.sections.ourWork}</h2>
          </div>
          <a href="https://www.instagram.com/26.mh_studio/" target="_blank" rel="noopener" class="btn-outline sm">{tr.sections.seeInstagram}</a>
        </div>
      </Reveal>
      <InstagramGrid locale={locale} />

      <div class="work-grid">
        {works.map((w, i) => (
          <Reveal delay={i * 60}>
            <div class={`work-card wc-${w.style}`}>
              <div class="wc-inner">
                <div class="wc-visual"><div class="wc-brand">{w.title.split(' ')[0]}</div></div>
                <div class="wc-overlay">
                  <span class="wc-cat">{w.cat}</span>
                  <span class="wc-name">{w.title}</span>
                </div>
              </div>
            </div>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section about-section" id="about">
    <div class={`container about-inner${rtl ? ' rtl' : ''}`}>
      <Reveal>
        <div class="about-visual">
          <div class="av-bg"></div>
          <div class="av-content">
            <div class="av-monogram">MH</div>
            <div class="av-stats">
              <div><span>50+</span><small>{tr.stats.projects}</small></div>
              <div><span>30+</span><small>{tr.stats.clients}</small></div>
              <div><span>4</span><small>{tr.stats.services}</small></div>
            </div>
          </div>
        </div>
      </Reveal>
      <div class={`about-text${rtl ? ' rtl' : ''}`}>
        <Reveal delay={100}>
          <div class="eyebrow">{tr.sections.ourStudio}</div>
          <h2 class="section-title">{tr.sections.weAre} <em>MH STUDIO</em></h2>
        </Reveal>
        <Reveal delay={180}>
          <p>{tr.about.p1}</p>
          <p>{tr.about.p2}</p>
        </Reveal>
        <Reveal delay={240}>
          <div class="about-tools">
            {['Adobe Suite','Figma','After Effects','Midjourney','Runway AI','Blender'].map(t => (
              <span class="tool-chip">{t}</span>
            ))}
          </div>
        </Reveal>
        <Reveal delay={300}>
          <a href={localePath(locale, '/#contact')} class="btn-primary">{tr.about.btnStart}</a>
        </Reveal>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="contact-section" id="contact">
    <Orbs />
    <div class={`container contact-inner${rtl ? ' rtl' : ''}`}>
      <Reveal>
        <div class="eyebrow center">{tr.sections.letsBuild}</div>
        <h2 class="contact-title">{tr.sections.haveProject}<br/><em>{tr.sections.haveProjectEm}</em></h2>
        <p class="contact-sub">{tr.sections.contactSub}</p>
        <div class="contact-actions">
          <a href="mailto:hello@26mhstudio.com" class="btn-primary lg">{tr.sections.sendMessage}</a>
          <a href="https://www.instagram.com/26.mh_studio/" target="_blank" rel="noopener" class="btn-outline">{tr.sections.dmInstagram}</a>
        </div>
      </Reveal>
    </div>
  </section>
</Layout>

<style>
.hero { min-height:100vh; display:flex; align-items:center; position:relative; overflow:hidden; padding-top:100px; }
.hero-noise { position:absolute; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E"); pointer-events:none; }
.hero-content { position:relative; z-index:2; padding-top:60px; padding-bottom:120px; }
.hero-content.rtl { text-align:right; }
.hero-label { display:inline-flex; align-items:center; gap:10px; font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--purple); margin-bottom:40px; }
.dot { width:6px; height:6px; border-radius:50%; background:var(--purple); animation:pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }
.hero-title { font-family:'Syne',sans-serif; font-size:clamp(52px,8vw,120px); font-weight:800; line-height:0.93; letter-spacing:-0.04em; margin-bottom:36px; }
.line-wrap { display:block; overflow:hidden; }
.line { display:inline-block; animation:slideUp 0.9s cubic-bezier(0.16,1,0.3,1) both; }
.accent-word { color:var(--purple); }
.italic-word { font-style:italic; color:var(--purple-light); }
.line-wrap:nth-child(2) .line { animation-delay:0.12s; }
@keyframes slideUp { from{transform:translateY(110%);opacity:0} to{transform:translateY(0);opacity:1} }
.hero-sub { font-size:1rem; line-height:1.8; color:var(--muted); max-width:480px; margin-bottom:48px; white-space:pre-line; }
.hero-content.rtl .hero-sub { margin-right:0; }
.hero-actions { display:flex; gap:16px; flex-wrap:wrap; margin-bottom:80px; }
.hero-content.rtl .hero-actions { justify-content:flex-end; }
.hero-marquee { overflow:hidden; border-top:1px solid var(--border); padding-top:24px; }
.marquee-track { display:flex; gap:32px; white-space:nowrap; animation:marquee 22s linear infinite; font-family:'Syne',sans-serif; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted); }
.rtl .marquee-track { animation-direction:reverse; }
.marquee-track .sep { color:var(--purple); }
@keyframes marquee { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.hero-scroll { position:absolute; bottom:40px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:10px; font-size:1rem; color:var(--muted); z-index:2; }
.scroll-line { width:1px; height:48px; background:linear-gradient(to bottom,var(--purple),transparent); animation:scrollPulse 1.8s ease-in-out infinite; }
@keyframes scrollPulse { 0%,100%{opacity:1} 50%{opacity:0.2} }

.btn-primary { display:inline-flex; align-items:center; gap:8px; background:var(--purple); color:var(--bg); padding:14px 32px; font-family:'Syne',sans-serif; font-size:0.82rem; font-weight:600; letter-spacing:0.06em; text-decoration:none; border-radius:2px; transition:background 0.2s,transform 0.2s; text-transform:uppercase; }
.btn-primary:hover { background:var(--purple-light); transform:translateY(-2px); }
.btn-primary.lg { padding:18px 40px; font-size:0.9rem; }
.btn-outline { display:inline-flex; align-items:center; gap:8px; border:1px solid var(--border); color:var(--white); padding:14px 32px; font-family:'Syne',sans-serif; font-size:0.82rem; font-weight:500; letter-spacing:0.06em; text-decoration:none; border-radius:2px; transition:border-color 0.2s,color 0.2s,transform 0.2s; text-transform:uppercase; }
.btn-outline:hover { border-color:var(--purple); color:var(--purple); transform:translateY(-2px); }
.btn-outline.sm { padding:10px 20px; font-size:0.72rem; }

.section { padding:120px 0; }
.section-head { margin-bottom:64px; }
.section-head.rtl { text-align:right; }
.section-head.split { display:flex; align-items:flex-end; justify-content:space-between; }
.section-head.split.rtl { flex-direction:row-reverse; }
.eyebrow { font-size:0.68rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--purple); margin-bottom:12px; display:block; }
.eyebrow.center { text-align:center; }
.section-title { font-family:'Syne',sans-serif; font-size:clamp(32px,4vw,52px); font-weight:800; letter-spacing:-0.03em; line-height:1.05; }
.section-title em { font-style:italic; color:var(--purple); }

.services-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:2px; background:var(--border); }
.service-card { background:var(--bg); padding:48px 40px; text-decoration:none; color:inherit; position:relative; overflow:hidden; transition:background 0.3s; display:flex; flex-direction:column; }
.service-card.rtl { text-align:right; }
.service-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; background:var(--purple); transform:scaleX(0); transform-origin:left; transition:transform 0.4s ease; }
.service-card.rtl::after { transform-origin:right; }
.service-card:hover { background:var(--bg-card); }
.service-card:hover::after { transform:scaleX(1); }
.coming-soon-card { opacity:0.5; pointer-events:none; }
.sc-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:28px; }
.sc-header.rtl { flex-direction:row-reverse; }
.sc-num { font-family:'Syne',sans-serif; font-size:0.72rem; color:var(--muted); letter-spacing:0.1em; }
.sc-tag { font-size:0.6rem; letter-spacing:0.12em; text-transform:uppercase; background:rgba(147,144,223,0.12); color:var(--purple); padding:4px 10px; border-radius:20px; border:1px solid var(--border); }
.sc-icon { width:40px; height:40px; color:var(--purple); margin-bottom:24px; }
.sc-icon :global(svg) { width:100%; height:100%; }
.sc-title { font-family:'Syne',sans-serif; font-size:1.3rem; font-weight:700; margin-bottom:14px; }
.sc-desc { font-size:0.88rem; line-height:1.8; color:var(--muted); flex:1; }
.sc-cta { display:flex; align-items:center; gap:8px; margin-top:28px; font-size:0.75rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--purple); font-weight:500; }
.service-card.rtl .sc-cta { flex-direction:row-reverse; }
.sc-cta svg { width:18px; height:18px; transition:transform 0.2s; }
.service-card:not(.rtl):hover .sc-cta svg { transform:translateX(4px); }
.service-card.rtl:hover .sc-cta svg { transform:translateX(-4px); }

.work-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; background:var(--border); }
.work-card { aspect-ratio:4/3; overflow:hidden; }
.wc-inner { width:100%; height:100%; position:relative; overflow:hidden; }
.wc-visual { width:100%; height:100%; display:flex; align-items:center; justify-content:center; transition:transform 0.5s ease; }
.work-card:hover .wc-visual { transform:scale(1.06); }
.wc-brand { font-family:'Syne',sans-serif; font-size:2.4rem; font-weight:800; color:rgba(255,255,255,0.07); letter-spacing:-0.05em; text-transform:uppercase; }
.wc-w1 .wc-visual{background:linear-gradient(135deg,#0e0a1a 0%,#1e0f2f 60%,#3d1860 100%)}
.wc-w2 .wc-visual{background:linear-gradient(135deg,#08101a 0%,#0d1e38 60%,#193d6e 100%)}
.wc-w3 .wc-visual{background:linear-gradient(135deg,#0a1008 0%,#152408 60%,#2a4a10 100%)}
.wc-w4 .wc-visual{background:linear-gradient(135deg,#0f0f0f 0%,#1a1a1a 60%,#303030 100%)}
.wc-w5 .wc-visual{background:linear-gradient(135deg,#1a0510 0%,#2f0820 60%,#5e1040 100%)}
.wc-w6 .wc-visual{background:linear-gradient(135deg,#0a080f 0%,#1a1030 60%,#2d1a52 100%)}
.wc-overlay { position:absolute; inset:0; background:rgba(8,8,15,0.82); opacity:0; display:flex; flex-direction:column; align-items:flex-start; justify-content:flex-end; padding:28px; transition:opacity 0.3s; }
.work-card:hover .wc-overlay { opacity:1; }
.wc-cat { font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--purple); margin-bottom:6px; }
.wc-name { font-family:'Syne',sans-serif; font-size:1.1rem; font-weight:700; color:var(--white); }

.about-section { background:var(--bg-surface); }
.about-inner { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; }
.about-inner.rtl { direction:rtl; }
.about-visual { aspect-ratio:1; background:var(--bg-card); border:1px solid var(--border); position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; }
.av-bg { position:absolute; inset:0; background:radial-gradient(circle at 40% 40%,rgba(147,144,223,0.15) 0%,transparent 60%); }
.av-content { position:relative; z-index:2; text-align:center; }
.av-monogram { font-family:'Syne',sans-serif; font-size:8rem; font-weight:800; color:rgba(147,144,223,0.18); line-height:1; letter-spacing:-0.05em; }
.av-stats { display:flex; gap:32px; justify-content:center; margin-top:24px; }
.av-stats div { text-align:center; }
.av-stats span { font-family:'Syne',sans-serif; font-size:1.8rem; font-weight:800; color:var(--white); display:block; }
.av-stats small { font-size:0.7rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--muted); }
.about-text { display:flex; flex-direction:column; gap:0; }
.about-text.rtl { text-align:right; }
.about-text .eyebrow { margin-bottom:12px; }
.about-text .section-title { margin-bottom:28px; }
.about-text p { font-size:0.92rem; line-height:1.9; color:var(--muted); margin-bottom:16px; }
.about-tools { display:flex; flex-wrap:wrap; gap:8px; margin:24px 0 36px; }
.about-text.rtl .about-tools { justify-content:flex-end; }
.tool-chip { font-size:0.72rem; letter-spacing:0.06em; background:var(--bg-card); color:var(--muted); border:1px solid var(--border); padding:6px 14px; border-radius:20px; }

.contact-section { padding:160px 0; text-align:center; position:relative; overflow:hidden; }
.contact-inner { position:relative; z-index:2; }
.contact-inner.rtl { direction:rtl; }
.contact-title { font-family:'Syne',sans-serif; font-size:clamp(48px,7vw,100px); font-weight:800; letter-spacing:-0.04em; line-height:1; margin:20px 0 28px; }
.contact-title em { font-style:italic; color:var(--purple); }
.contact-sub { font-size:1rem; color:var(--muted); max-width:440px; margin:0 auto 48px; line-height:1.8; }
.contact-actions { display:flex; gap:16px; justify-content:center; flex-wrap:wrap; }

@media(max-width:900px){ .services-grid{grid-template-columns:1fr} .work-grid{grid-template-columns:repeat(2,1fr)} .about-inner{grid-template-columns:1fr;gap:48px} .section-head.split{flex-direction:column;align-items:flex-start;gap:20px} .section-head.split.rtl{align-items:flex-end} }
@media(max-width:600px){ .work-grid{grid-template-columns:1fr} }
</style>
