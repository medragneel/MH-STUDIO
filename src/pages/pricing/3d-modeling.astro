---
import Layout from '../../layouts/Layout.astro';
import Reveal from '../../components/Reveal.astro';
import Orbs from '../../components/Orbs.astro';
---

<Layout
  title="3D Modeling — Coming Soon — 26.MH Studio"
  description="Hyper-realistic 3D product renders and visualizations. Coming soon from 26.MH Studio."
>
  <section class="cs-section">
    <Orbs />
    <div class="container cs-inner">

      <Reveal>
        <a href="/#services" class="back-link">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M16 10H4M10 4l-6 6 6 6"/></svg>
          All Services
        </a>

        <div class="cs-badge">Coming Soon</div>

        <h1 class="cs-title">3D <em>Modeling</em></h1>

        <p class="cs-sub">
          Hyper-realistic 3D renders, product visualizations, and immersive brand environments.<br/>
          The next level of visual storytelling — launching soon.
        </p>
      </Reveal>

      <Reveal delay={150}>
        <div class="cs-preview">
          <div class="cube-wrap" aria-hidden="true">
            <div class="cube">
              <div class="face front"></div>
              <div class="face back"></div>
              <div class="face left"></div>
              <div class="face right"></div>
              <div class="face top"></div>
              <div class="face bottom"></div>
            </div>
          </div>
          <div class="cs-preview-text">
            <span>In development</span>
            <div class="progress-bar"><div class="progress-fill"></div></div>
            <span class="prog-label">~70% complete</span>
          </div>
        </div>
      </Reveal>

      <Reveal delay={220}>
        <div class="cs-features">
          <h2>What's coming</h2>
          <div class="feat-grid">
            {[
              { icon: '◈', title: 'Product Renders',   desc: 'Photorealistic 3D renders of your products — no photography needed.' },
              { icon: '◉', title: 'Scene Visualization', desc: 'Lifestyle 3D scenes with your product placed in stunning environments.' },
              { icon: '◫', title: 'Packaging in 3D',   desc: 'See your packaging design come to life before going to print.' },
              { icon: '◬', title: 'Motion & Turntable', desc: '360° rotating product videos for e-commerce and ads.' },
              { icon: '◭', title: 'Brand Environments', desc: 'Full 3D spaces — storefronts, digital showrooms, virtual backdrops.' },
              { icon: '◯', title: 'Asset Library',      desc: 'Reusable 3D brand assets you own and can deploy everywhere.' },
            ].map(f => (
              <div class="feat-card">
                <span class="feat-icon">{f.icon}</span>
                <strong>{f.title}</strong>
                <p>{f.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </Reveal>

      <Reveal delay={300}>
        <div class="cs-notify">
          <h3>Get notified when we launch</h3>
          <p>Be first in line — leave your email and we'll reach out the moment 3D is live, with an exclusive early-bird discount.</p>
          <form class="notify-form" onsubmit="handleSubmit(event)">
            <input type="email" placeholder="your@email.com" required />
            <button type="submit">Notify Me →</button>
          </form>
          <div id="success-msg" class="success-msg" style="display:none">
            ✓ You're on the list! We'll be in touch soon.
          </div>
        </div>
      </Reveal>

    </div>
  </section>
</Layout>

<style>
.cs-section {
  min-height: 100vh;
  padding: 160px 0 120px;
  position: relative; overflow: hidden;
}
.cs-inner { position: relative; z-index: 2; }
.back-link {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--muted); text-decoration: none;
  margin-bottom: 40px; transition: color 0.2s;
}
.back-link:hover { color: var(--purple); }
.back-link svg { width: 16px; height: 16px; }
.cs-badge {
  display: inline-block;
  background: rgba(147,144,223,0.12); color: var(--purple);
  border: 1px solid var(--border); border-radius: 20px;
  font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
  padding: 6px 16px; margin-bottom: 28px;
  font-family: var(--ff-display); font-weight: 600;
}
.cs-title {
  font-family: var(--ff-display); font-size: clamp(52px, 8vw, 110px);
  font-weight: 800; letter-spacing: -0.04em; line-height: 0.92;
  margin-bottom: 32px;
}
.cs-title em { font-style: italic; color: var(--purple); }
.cs-sub {
  font-size: 1.05rem; line-height: 1.8; color: var(--muted);
  max-width: 560px; margin-bottom: 80px;
}

/* 3D Cube animation */
.cs-preview {
  display: flex; align-items: center; gap: 60px;
  margin-bottom: 100px; flex-wrap: wrap;
}
.cube-wrap {
  width: 120px; height: 120px;
  perspective: 400px; flex-shrink: 0;
}
.cube {
  width: 100%; height: 100%;
  transform-style: preserve-3d;
  animation: rotateCube 8s linear infinite;
}
@keyframes rotateCube {
  from { transform: rotateX(20deg) rotateY(0deg); }
  to   { transform: rotateX(20deg) rotateY(360deg); }
}
.face {
  position: absolute; width: 120px; height: 120px;
  border: 1px solid rgba(147,144,223,0.3);
  background: rgba(147,144,223,0.04);
}
.front  { transform: translateZ(60px); }
.back   { transform: rotateY(180deg) translateZ(60px); }
.left   { transform: rotateY(-90deg) translateZ(60px); }
.right  { transform: rotateY(90deg)  translateZ(60px); }
.top    { transform: rotateX(90deg)  translateZ(60px); }
.bottom { transform: rotateX(-90deg) translateZ(60px); }

.cs-preview-text { display: flex; flex-direction: column; gap: 10px; }
.cs-preview-text span { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
.progress-bar {
  width: 220px; height: 2px;
  background: var(--border); border-radius: 2px; overflow: hidden;
}
.progress-fill {
  height: 100%; width: 70%;
  background: linear-gradient(90deg, var(--purple-deep), var(--purple-light));
  border-radius: 2px;
  animation: loadFill 1.5s cubic-bezier(0.16,1,0.3,1) both;
  animation-delay: 0.5s;
}
@keyframes loadFill { from { width: 0; } to { width: 70%; } }
.prog-label { color: var(--purple) !important; font-weight: 600; }

/* Features */
.cs-features { margin-bottom: 100px; }
.cs-features h2 {
  font-family: var(--ff-display); font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 800; letter-spacing: -0.03em; margin-bottom: 48px;
}
.feat-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  background: var(--border);
}
.feat-card {
  background: var(--bg-card); padding: 36px 32px;
  display: flex; flex-direction: column; gap: 12px;
}
.feat-icon { font-size: 1.4rem; color: var(--purple); }
.feat-card strong { font-family: var(--ff-display); font-size: 1rem; font-weight: 700; color: var(--white); }
.feat-card p { font-size: 0.84rem; line-height: 1.7; color: var(--muted); }

/* Notify */
.cs-notify {
  background: var(--bg-card); border: 1px solid var(--border);
  padding: 52px; max-width: 600px;
}
.cs-notify h3 {
  font-family: var(--ff-display); font-size: 1.5rem; font-weight: 800;
  letter-spacing: -0.02em; margin-bottom: 12px;
}
.cs-notify p { font-size: 0.88rem; line-height: 1.8; color: var(--muted); margin-bottom: 28px; }
.notify-form { display: flex; gap: 0; }
.notify-form input {
  flex: 1; background: var(--bg-surface); border: 1px solid var(--border);
  border-right: none; padding: 14px 20px; color: var(--white);
  font-family: var(--ff-body); font-size: 0.9rem; outline: none;
  transition: border-color 0.2s;
}
.notify-form input:focus { border-color: var(--purple); }
.notify-form input::placeholder { color: var(--muted); }
.notify-form button {
  background: var(--purple); color: var(--bg);
  border: none; padding: 14px 28px; cursor: pointer;
  font-family: var(--ff-display); font-size: 0.8rem;
  font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
  transition: background 0.2s;
}
.notify-form button:hover { background: var(--purple-light); }
.success-msg {
  margin-top: 16px; font-size: 0.85rem; color: var(--purple);
  font-family: var(--ff-display); font-weight: 600;
}

@media (max-width: 768px) {
  .feat-grid { grid-template-columns: 1fr 1fr; }
  .cs-notify { padding: 32px 24px; }
  .notify-form { flex-direction: column; }
  .notify-form input { border-right: 1px solid var(--border); border-bottom: none; }
}
@media (max-width: 500px) {
  .feat-grid { grid-template-columns: 1fr; }
}
</style>

<script>
function handleSubmit(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  form.style.display = 'none';
  const msg = document.getElementById('success-msg');
  if (msg) msg.style.display = 'block';
}
</script>
